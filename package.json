{
  "name": "cproxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun build --compile --minify ./src/index.ts --outfile ./dist/cproxy",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "verify": "bun run check && bun run typecheck"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@elysiajs/html": "^1.4.2",
    "elysia": "^1.2.25",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/bun": "latest",
    "typescript": "^6.0.3"
  }
}
